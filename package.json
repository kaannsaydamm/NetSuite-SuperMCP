    "check:restlet-contract": "bun run scripts/check-restlet-contract.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "hono": "4.10.5",
    "ky": "1.14.1",
    "pino": "10.1.0",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@types/bun": "1.3.6",
    "typescript": "5.9.3"
  }
}
