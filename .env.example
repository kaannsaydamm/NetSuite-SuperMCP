MCP_SERVER_NAME=NetSuite SuperMCP
# Optional: leave unset so ns_getSuperMcpVersion reports the installed package version.
MCP_SERVER_VERSION_OVERRIDE=
MCP_HOST=127.0.0.1
MCP_PORT=3025
MCP_BEARER_TOKEN=change-me-token-please
NETSUITE_ACCOUNT_ID=1234567_SB1
NETSUITE_ENVIRONMENT=sandbox
NETSUITE_BASE_URL=https://1234567-sb1.suitetalk.api.netsuite.com
NETSUITE_RESTLET_URL=https://1234567-sb1.restlets.api.netsuite.com/app/site/hosting/restlet.nl?script=customscript_supermcp_action&deploy=customdeploy_supermcp_action
NETSUITE_OAUTH_FLOW=authorization_code
NETSUITE_AUTHORIZATION_URL=https://1234567-sb1.app.netsuite.com/app/login/oauth2/authorize.nl
NETSUITE_CLIENT_ID=change-me
NETSUITE_CLIENT_SECRET=change-me
NETSUITE_REDIRECT_URI=https://127.0.0.1:3026/oauth/callback
NETSUITE_REFRESH_TOKEN=
NETSUITE_CONSUMER_KEY=change-me
NETSUITE_CERTIFICATE_ID=change-me
NETSUITE_PRIVATE_KEY_PEM_BASE64=base64-pem-here
NETSUITE_TOKEN_URL=https://1234567-sb1.suitetalk.api.netsuite.com/services/rest/auth/oauth2/v1/token
# Optional diagnostics-only identity. It is never used as a fallback for business operations.
# NETSUITE_MANAGEMENT_ACCOUNT_ID=1234567_SB1
# NETSUITE_MANAGEMENT_ENVIRONMENT=sandbox
# NETSUITE_MANAGEMENT_BASE_URL=https://1234567-sb1.suitetalk.api.netsuite.com
# NETSUITE_MANAGEMENT_RESTLET_URL=https://1234567-sb1.restlets.api.netsuite.com/app/site/hosting/restlet.nl?script=customscript_supermcp_action&deploy=customdeploy_supermcp_action
# NETSUITE_MANAGEMENT_TOKEN_URL=https://1234567-sb1.suitetalk.api.netsuite.com/services/rest/auth/oauth2/v1/token
# NETSUITE_MANAGEMENT_OAUTH_FLOW=authorization_code
# NETSUITE_MANAGEMENT_CLIENT_ID=
# NETSUITE_MANAGEMENT_CLIENT_SECRET=
# NETSUITE_MANAGEMENT_REFRESH_TOKEN=
AUDIT_LOG_PATH=./data/audit.ndjson
JOB_STORE_PATH=./data/read-jobs.json
EXPORT_DIRECTORY=./data/exports
INTEGRATION_STORE_PATH=./data/integrations.json
CUSTOMIZATION_STORE_PATH=./data/customization-deployments.json
CUSTOMIZATION_PROJECT_DIRECTORY=./data/customization-projects
SEMANTIC_STORE_PATH=./data/semantic-definitions.json
RUNBOOK_STORE_PATH=./data/runbooks.json
# Optional comma-separated provider-approved local-only repair classes. Empty is safest.
RUNBOOK_LOW_RISK_REPAIR_CLASSES=
# Optional. By default SuperMCP reuses an existing MCP/OAuth secret so cursors survive restarts.
# MCP_CURSOR_SECRET=
